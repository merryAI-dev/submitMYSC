# Frontend
VITE_FIREBASE_AUTH_ENABLED=true
VITE_FIREBASE_USE_ENV_CONFIG=true
VITE_FIRESTORE_CORE_ENABLED=false
VITE_PLATFORM_API_ENABLED=true
VITE_PLATFORM_API_BASE_URL=
VITE_DEFAULT_ORG_ID=mysc
VITE_ALLOWED_EMAIL_DOMAINS=mysc.co.kr
VITE_SUBMIT_MYSC_ADMIN_EMAILS=

# Firebase Web SDK
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Public submission security
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
BFF_TURNSTILE_ENABLED=true

# BFF auth and CORS
BFF_AUTH_MODE=firebase_required
BFF_ALLOWED_EMAIL_DOMAINS=mysc.co.kr
BFF_SUBMIT_MYSC_ADMIN_EMAILS=
BFF_ALLOWED_ORIGINS=https://submit-mysc.com,https://www.submit-mysc.com,https://submit-mysc.vercel.app
BFF_JSON_LIMIT=18mb

# Firebase Admin / Google service account
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_SERVICE_ACCOUNT_BASE64=
GOOGLE_DRIVE_SHARED_DRIVE_ID=
GOOGLE_DRIVE_EVIDENCE_ROOT_FOLDER_ID=

# Optional exports
VITE_PAYMENT_EVIDENCE_SPREADSHEET_ID=
PAYMENT_EVIDENCE_PUBLIC_BASE_URL=https://submit-mysc.com
PAYMENT_EVIDENCE_MAX_UPLOAD_BYTES=12582912
